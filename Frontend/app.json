{
  "expo": {
    "name": "MoveWise",
    "slug": "MoveWise",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/img1.png",
    "scheme": "movewise",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "config": {
        "googleMapsApiKey": "AIzaSyAOVYRIgupAurZup5y1PRh8Ismb1A3lLao"
      },
      "supportsTablet": true
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAOVYRIgupAurZup5y1PRh8Ismb1A3lLao"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/img2.png",
        "backgroundImage": "./assets/images/background.png",
        "monochromeImage": "./assets/images/img3.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.shreyansh44.MoveWise"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/img1.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/img3.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "676ca6b3-a7d1-4d4e-a5fd-46b3811837b7"
      }
    }
  }
}
